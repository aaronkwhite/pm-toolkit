---
const navLinks = [
  { href: '/docs/', label: 'Docs' },
  { href: '/changelog/', label: 'Changelog' },
];
const currentPath = Astro.url.pathname;
---

<header id="main-header" class="nav-new">
  <div class="nav-inner-new">
    <!-- Logo -->
    <a href="/" class="nav-logo-new">
      <span class="mark">
        <img class="logo-mark logo-mark-light" src="/images/logos/pm-toolkit-logo-mark.svg" alt="" width="28" height="28" />
        <img class="logo-mark logo-mark-dark" src="/images/logos/pm-toolkit-logo-mark-dark.svg" alt="" width="28" height="28" />
      </span>
      <span>PM Toolkit</span>
    </a>

    <!-- Navigation -->
    <div class="nav-links-new">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link-new', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
      <a class="nav-link-new" href="https://github.com/aaronkwhite/pm-toolkit" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/>
        </svg>
      </a>
    </div>

    <!-- Actions -->
    <div class="nav-actions-new">
      <button class="theme-toggle-pill" id="theme-toggle" aria-label="Toggle theme">
        <span class="knob">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
      </button>
      <a class="btn-new btn-accent-new" style="padding: 8px 14px; font-size: 0.85rem; border-radius: 10px;" href="https://open-vsx.org/extension/aaronkwhite/pm-toolkit" target="_blank" rel="noopener noreferrer">Install</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  if (header) {
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;
      header.classList.toggle('scrolled', y > 8);
      // Hide when scrolling down past 80px, reveal when scrolling up
      if (y > 80) {
        header.classList.toggle('nav-hidden', y > lastY);
      } else {
        header.classList.remove('nav-hidden');
      }
      lastY = y;
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
    update();
  }
</script>
