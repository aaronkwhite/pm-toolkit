---
import { getLatestPublicVersion, getExpectedNextVersion } from '../lib/version';

const { tag: version } = await getLatestPublicVersion();
const { tag: nextVersion } = getExpectedNextVersion();
const versionSuffix = ' · MIT licensed · open source';
const defaultVersionText = `${version}${versionSuffix}`;
const flagVersionText = `${nextVersion}${versionSuffix}`;
---

<!-- Page-level grid: aurora wash + animated grid lines + mint pulses -->
<div class="page-grid" aria-hidden="true">
  <div class="aurora"></div>
  <div class="grid-overlay">
    <!-- Horizontal pulses -->
    <div class="grid-pulse h" style="top:56px; --pulse-duration:9.2s; --pulse-delay:-1.4s;"></div>
    <div class="grid-pulse h" style="top:168px; --pulse-duration:11.0s; --pulse-delay:-5.8s;"></div>
    <div class="grid-pulse h" style="top:280px; --pulse-duration:8.4s; --pulse-delay:-3.2s;"></div>
    <div class="grid-pulse h" style="top:448px; --pulse-duration:12.6s; --pulse-delay:-7.5s;"></div>
    <!-- Vertical pulses -->
    <div class="grid-pulse v" style="left:112px; --pulse-duration:10.4s; --pulse-delay:-2.1s;"></div>
    <div class="grid-pulse v" style="left:336px; --pulse-duration:13.8s; --pulse-delay:-6.6s;"></div>
    <div class="grid-pulse v" style="left:616px; --pulse-duration:9.6s; --pulse-delay:-4.3s;"></div>
    <div class="grid-pulse v" style="left:896px; --pulse-duration:11.8s; --pulse-delay:-0.8s;"></div>
  </div>
</div>

<section class="hero-section">
  <div style="max-width: 1200px; margin: 0 auto; padding-inline: clamp(20px, 4vw, 48px);">
    <div class="hero-new">
      <!-- Badge -->
      <div class="hero-eyebrow-new">
        <span class="chip-dot"></span>
        Free forever
      </div>

      <!-- Animated headline -->
      <h1 class="type-headline" id="hero-headline" aria-label="Your docs. Your editor.">
        <span class="word">Your</span>&nbsp;<span class="word">docs.</span>&nbsp;<span class="word word-accent">Your</span>&nbsp;<span class="word word-accent">editor.</span>
      </h1>

      <!-- Subheadline -->
      <p class="hero-sub-new" id="hero-sub">
        Visual markdown, kanban boards, and diagrams, right where you code.
      </p>

      <!-- CTAs -->
      <div class="hero-cta-new" id="hero-cta">
        <a class="btn-new btn-accent-new" href="https://open-vsx.org/extension/aaronkwhite/pm-toolkit" target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3l7.07 17 2.51-7.42 7.42-2.51L3 3z"/></svg>
          Install for Cursor
        </a>
        <a class="btn-new btn-ghost-new" href="https://marketplace.visualstudio.com/items?itemName=aaronkwhite.pm-toolkit" target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 4l-9 8 9 8V4z"/><path d="M21 4L7 13l-4-3 4-3 14-3z" opacity="0.6"/></svg>
          Install for VS Code
        </a>
      </div>

      <!-- Version (text swapped at runtime by the PostHog feature-flag callback) -->
      <p
        class="hero-version-new"
        id="hero-version"
        data-version-text-default={defaultVersionText}
        data-version-text-flag={flagVersionText}
      >{defaultVersionText}</p>

      <!-- Hero screenshot -->
      <div class="hero-media-new" id="hero-media">
        <div class="hero-media-bg" aria-hidden="true"></div>
        <div class="hero-media-float animate-float">
          <img
            src="/images/pmtoolkit-visual-editor.png"
            srcset="/images/pmtoolkit-visual-editor.png 1160w, /images/pmtoolkit-visual-editor@2x.png 2320w"
            sizes="(max-width: 1024px) 100vw, 1080px"
            alt="PM Toolkit visual markdown editor in Cursor"
            loading="eager"
            width="1160"
            height="750"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Stagger the TypedHeadline words in after DOMContentLoaded
  function initHero() {
    const words = document.querySelectorAll('#hero-headline .word');
    words.forEach((w, i) => {
      setTimeout(() => w.classList.add('in'), 80 + i * 140);
    });
    // Reveal remaining elements
    ['hero-sub', 'hero-cta', 'hero-version', 'hero-media'].forEach((id) => {
      const el = document.getElementById(id);
      if (el) requestAnimationFrame(() => el.classList.add('in'));
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
