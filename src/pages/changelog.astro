---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { readFileSync } from 'node:fs';

let changelogRaw = '';
try {
  changelogRaw = readFileSync(new URL('../../CHANGELOG.md', import.meta.url), 'utf-8');
} catch {
  changelogRaw = '## No changelog available\n\nCould not read CHANGELOG.md.';
}

interface ChangelogEntry {
  version: string;
  date: string;
  intro: string;
  categories: { name: string; items: string[] }[];
}

const entries: ChangelogEntry[] = [];
const versionRegex = /^## \[(.+?)\] - (\d{4}-\d{2}-\d{2})/;
const categoryRegex = /^### (.+)/;

const lines = changelogRaw.split('\n');
let currentEntry: ChangelogEntry | null = null;
let currentCategory: { name: string; items: string[] } | null = null;
let introLines: string[] = [];
let inIntro = false;

for (const line of lines) {
  const versionMatch = line.match(versionRegex);
  if (versionMatch) {
    if (currentEntry) {
      currentEntry.intro = introLines.join('\n').trim();
    }
    introLines = [];
    inIntro = true;
    currentEntry = { version: versionMatch[1], date: versionMatch[2], intro: '', categories: [] };
    entries.push(currentEntry);
    currentCategory = null;
    continue;
  }
  if (!currentEntry) continue;
  const categoryMatch = line.match(categoryRegex);
  if (categoryMatch) {
    inIntro = false;
    currentCategory = { name: categoryMatch[1], items: [] };
    currentEntry.categories.push(currentCategory);
    continue;
  }
  if (inIntro && line.trim() && !line.startsWith('###')) {
    introLines.push(line);
  } else if (currentCategory && line.startsWith('- ')) {
    currentCategory.items.push(line.slice(2));
  } else if (currentCategory && line.startsWith('  - ')) {
    const last = currentCategory.items.length - 1;
    if (last >= 0) currentCategory.items[last] += '\n' + line;
  }
}
if (currentEntry) currentEntry.intro = introLines.join('\n').trim();

function tagClass(name: string): string {
  switch (name.toLowerCase()) {
    case 'added': return 'cl-tag cl-tag-added';
    case 'fixed': return 'cl-tag cl-tag-fixed';
    case 'changed': return 'cl-tag cl-tag-changed';
    case 'removed': return 'cl-tag cl-tag-removed';
    case 'documentation': return 'cl-tag cl-tag-docs';
    default: return 'cl-tag cl-tag-added';
  }
}

function formatItem(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/`(.+?)`/g, '<code>$1</code>');
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  } catch { return dateStr; }
}
---

<Layout title="Changelog — PM Toolkit" description="New features and fixes shipping regularly. Free forever.">
  <Header />

  <main>
    <!-- Hero -->
    <section style="padding-top: clamp(56px, 8vw, 100px); padding-bottom: clamp(28px, 4vw, 56px); position: relative; overflow: hidden;">
      <div class="aurora" style="opacity: 0.45;"></div>
      <div style="position: relative; z-index: 1; max-width: 880px; margin: 0 auto; padding-inline: clamp(20px, 4vw, 48px);">
        <p class="eyebrow-cl">Changelog</p>
        <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 500; letter-spacing: -0.03em; line-height: 1.05; margin: 12px 0 16px; color: var(--text);">What's new in PM Toolkit.</h1>
        <p style="color: var(--text-muted); font-size: clamp(1rem, 1.5vw, 1.2rem); max-width: 56ch;">
          New features and fixes shipping regularly. Free forever, no catch.
        </p>
      </div>
    </section>

    <!-- Entries -->
    <section style="padding-top: 0; padding-bottom: clamp(64px, 8vw, 120px);">
      <div class="changelog-layout">
        {entries.map((entry, i) => (
          <article class="changelog-entry-new">
            <div class="changelog-meta-new">
              <div class="changelog-version-row">
                <div class="changelog-version-new">v{entry.version}</div>
                {i === 0 && <span class="cl-tag cl-tag-sm cl-tag-latest">latest</span>}
              </div>
              <div class="changelog-date-new">{formatDate(entry.date)}</div>
            </div>
            <div class="prose-new" style="max-width: none;">
              {entry.intro && <p style="color: var(--text-muted); margin-bottom: 20px;" set:html={entry.intro.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/`(.+?)`/g, '<code>$1</code>')} />}
              {entry.categories.map((cat) => (
                cat.items.length > 0 && (
                  <div class="cl-section">
                    <span class={tagClass(cat.name)}>{cat.name}</span>
                    <ul>
                      {cat.items.map((item) => (
                        <li set:html={formatItem(item)} />
                      ))}
                    </ul>
                  </div>
                )
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="footer-new">
    <div class="footer-inner-new">
      <a href="/" style="display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 0.95rem; color: var(--text); text-decoration: none;">
        <span class="mark">
          <img class="logo-mark logo-mark-light" src="/images/logos/pm-toolkit-logo-mark.svg" alt="" width="24" height="24" />
          <img class="logo-mark logo-mark-dark" src="/images/logos/pm-toolkit-logo-mark-dark.svg" alt="" width="24" height="24" />
        </span>
        PM Toolkit
      </a>
      <p>Made for people who live in their editor.</p>
      <div class="footer-links-new">
        <a href="/docs/">Docs</a>
        <a href="/changelog/">Changelog</a>
        <a href="https://github.com/aaronkwhite/pm-toolkit" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .eyebrow-cl {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-deep);
  }
  [data-theme="dark"] .eyebrow-cl { color: var(--accent); }

  .cl-section { margin-bottom: 24px; }
  .cl-section > .cl-tag { display: inline-flex; margin-bottom: 12px; }
  .cl-section > ul { margin-top: 0; }

  .changelog-version-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
</style>
